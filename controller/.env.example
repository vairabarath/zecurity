DATABASE_URL=postgres://ztna:ztna_dev_secret@localhost:5432/ztna_platform?sslmode=disable
# Valkey (open-source Redis-compatible cache, Linux Foundation fork of Redis 7.2)
# Note: URL scheme is "redis://" — that is the wire protocol name, not the product.
#       The value redis://localhost:6379 is correct even when using Valkey.
VALKEY_URL=redis://localhost:6379
PORT=8080
ENV=development

JWT_SECRET=replace_with_32_plus_random_bytes

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback

# Separate OAuth app for the Rust CLI (desktop app type in Google Console)
CLIENT_GOOGLE_CLIENT_ID=your_client_app_google_client_id
CLIENT_GOOGLE_CLIENT_SECRET=your_client_app_google_client_secret

PKI_MASTER_SECRET=replace_with_64_plus_random_bytes

ALLOWED_ORIGIN=http://localhost:5173

# ── Connector sprint additions ───────────────────────────────────────────────
CONTROLLER_ADDR=localhost:9090
GRPC_PORT=9090
CONNECTOR_CERT_TTL=168h
CONNECTOR_ENROLLMENT_TOKEN_TTL=24h
CONNECTOR_HEARTBEAT_INTERVAL=30s
CONNECTOR_DISCONNECT_THRESHOLD=90s
CONNECTOR_RENEWAL_WINDOW=48h

# ── Shield sprint additions ──────────────────────────────────────────────────
SHIELD_CERT_TTL=168h
SHIELD_RENEWAL_WINDOW=48h
SHIELD_ENROLLMENT_TOKEN_TTL=24h
SHIELD_DISCONNECT_THRESHOLD=120s

# ── Client / Invitation sprint additions ────────────────────────────────────
APP_BASE_URL=https://app.zecurity.example.com
CONTROLLER_HOST=localhost:9090

# SMTP — leave unset in dev mode (invite links are logged to stdout instead)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=noreply@example.com
SMTP_PASSWORD=replace_with_smtp_password
